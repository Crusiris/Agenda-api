# ─── Entorno ────────────────────────────────────────────────────────────────
NODE_ENV=development          # production | development

# ─── Puerto ─────────────────────────────────────────────────────────────────
# Render lo asigna automáticamente; en local usa 8080
PORT=8080

# ─── Base de datos ───────────────────────────────────────────────────────────
# OPCIÓN A — Aiven / Render (recomendado para producción)
# Copia la "Service URI" desde el dashboard de Aiven:
# DB_URL=mysql://usuario:contraseña@host:puerto/nombre_bd?ssl-mode=REQUIRED

# OPCIÓN B — Variables individuales (desarrollo local)
DB_HOST=localhost
DB_PORT=3306
DB_NAME=agenda_escolar
DB_USER=root
DB_PASSWORD=

# Fuerza SSL aunque NODE_ENV no sea production (útil para staging)
# DB_SSL=true

# ─── CORS ────────────────────────────────────────────────────────────────────
# Lista de orígenes separados por coma. Usa * para permitir todos (solo dev).
# En producción pon la URL exacta de Vercel:
# CORS_ORIGIN=https://agenda-cliente.vercel.app,http://localhost:3000
CORS_ORIGIN=http://localhost:3000
